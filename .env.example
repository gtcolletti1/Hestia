# Environment
NODE_ENV=production
DEBUG=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=familyhub
POSTGRES_USER=familyhub
POSTGRES_PASSWORD=changeme-use-a-strong-password

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Google Calendar Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/integrations/google/callback

# Microsoft/Outlook Integration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost/api/integrations/microsoft/callback

# Weather (OpenWeatherMap)
OPENWEATHER_API_KEY=

# Home Assistant
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=

# Todoist
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# Calendar Sync Interval (seconds)
CALENDAR_SYNC_INTERVAL=300

# TLS (for production)
TLS_CERT_PATH=
TLS_KEY_PATH=
